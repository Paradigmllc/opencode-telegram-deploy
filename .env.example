# ============================================================
# Required — Bot will refuse to boot without these
# ============================================================

# @BotFather から取得した Bot Token
TELEGRAM_BOT_TOKEN=1234567890:REPLACE_ME

# 自分の Telegram numeric ID（@userinfobot で取得・@grinev/opencode-telegram-bot は単一 ID のみ）
TELEGRAM_ALLOWED_USER_ID=123456789

# Telegram bot のデフォルト LLM (OpenRouter 経由の DeepSeek V3.2 PRO)
OPENCODE_MODEL_PROVIDER=openrouter
OPENCODE_MODEL_ID=deepseek/deepseek-v3.2-exp

# OpenRouter API key — 全 LLM 呼び出しはここを通る
# 取得: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# GitHub Personal Access Token (classic) — repo + workflow + read:org scope
# 取得: https://github.com/settings/tokens
# これがあれば全 Paradigmllc リポを on-demand `gh repo clone` で取れる
GITHUB_TOKEN=ghp_REPLACE_ME

# ============================================================
# Optional — Git identity
# ============================================================
GIT_USER_NAME=Paradigm OpenCode Bot
GIT_USER_EMAIL=bot@paradigm.local

# ============================================================
# Optional — Boot-favorites (起動時に auto-clone するリポ)
# 空欄でも全 GitHub リポは on-demand で clone 可能
# 例: 普段触る 2-4 リポを並べておくと cold start が早い
# ============================================================
WORKSPACES_REPOS=Paradigmllc/dotfiles,Paradigmllc/Appexxme

# ============================================================
# Optional — Synergy with sibling agents
# ============================================================

# Slack #all-paradigm Webhook (push/deploy/migration 時に通知)
SLACK_WEBHOOK_URL=

# Paperclip API token (Telegram → 夜間バッチ Issue dispatch 用)
# paperclip.appexx.me で発行 (将来 Level 2 解禁後に有効化)
PAPERCLIP_API_TOKEN=

# ============================================================
# Optional — MCP credentials (referenced by opencode.json)
# ============================================================
SUPABASE_ACCESS_TOKEN=
